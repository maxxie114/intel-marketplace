# Nevermined — seller credentials
NVM_API_KEY=sandbox:your-seller-api-key
NVM_ENVIRONMENT=sandbox
NVM_PLAN_ID=your-plan-id
NVM_AGENT_ID=your-agent-id

# LLM — Claude (injected by Trinity, or set explicitly)
ANTHROPIC_API_KEY=sk-ant-your-key
MODEL_ID=claude-sonnet-4-6

# Apify — world data scraping
APIFY_API_KEY=apify_api_your_key_here

# EXA — general web + news search
EXA_API_KEY=your-exa-key-here

# ZeroClick — ad monetization (optional)
ZEROCLICK_API_KEY=your-zeroclick-key-here

# Cornelius knowledge base (internal — never expose to clients)
# Set to the Trinity agent URL e.g. http://localhost:2258 or internal Trinity URL
CORNELIUS_URL=

# Nevermined discovery — hackathon discovery API key (same as NVM_API_KEY usually)
NVM_DISCOVERY_API_KEY=sandbox:your-api-key

# Server
PORT=3000
A2A_PORT=9000

# Buyer registration URL (if also acting as buyer marketplace)
BUYER_URL=
